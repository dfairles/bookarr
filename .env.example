BOOKARR_SECRET_KEY=change-this-long-random-string
BOOKARR_DATABASE_URL=sqlite:///./data/bookarr.db

# Auth mode: audiobookshelf | jellyfin | local
BOOKARR_AUTH_MODE=audiobookshelf
AUDIOBOOKSHELF_URL=http://your-audiobookshelf-host:13378
JELLYFIN_URL=http://your-jellyfin-host:8096

# Local auth only: password for the auto-created admin account on first run
BOOKARR_ADMIN_SEED_PASSWORD=

# Set to true to send all requests straight to Listenarr without admin approval
BOOKARR_AUTO_APPROVE_ALL=false
# Set to false to require admin approval even for admin's own requests
BOOKARR_ADMIN_AUTO_APPROVE=true

LISTENARR_URL=http://listenarr:4545
LISTENARR_TOKEN=paste-listenarr-token-here
LISTENARR_AUTH_MODE=x-api-key
BOOKARR_STATUS_POLL_SECONDS=300
BOOKARR_COMPLETED_RETENTION_DAYS=30
